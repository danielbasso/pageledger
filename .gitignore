# Local environment (secrets / machine-specific) — .env.example is the tracked template
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/

# Terraform — never commit state or machine-specific vars
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform/terraform.tfvars

# OS / editor
.DS_Store
*.swp
