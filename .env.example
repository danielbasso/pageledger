# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RAW_TOPIC=wiki.events.raw
KAFKA_VALID_TOPIC=wiki.events.valid
KAFKA_DEADLETTER_TOPIC=wiki.events.deadletter

# Producer
MODE=FIXTURE                # FIXTURE (default, local) | LIVE (prod)
WIKI_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
FIXTURE_FILE=./fixtures/wiki_events_sample.jsonl
PLAYBACK_SPEED=1.0

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pageledger
POSTGRES_USER=
POSTGRES_PASSWORD=

# App
API_PORT=8000
